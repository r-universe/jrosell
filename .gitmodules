[submodule ".registry"]
	path = .registry
	url = https://github.com/jrosell/jrosell.r-universe.dev
	branch = HEAD
[submodule "ambhtmx"]
	path = ambhtmx
	url = https://github.com/jrosell/ambhtmx
[submodule "barn"]
	path = barn
	url = https://github.com/jrosell/barn
[submodule "gtakeout"]
	path = gtakeout
	url = https://github.com/jrosell/gtakeout
[submodule "jrrosell"]
	path = jrrosell
	url = https://github.com/jrosell/jrrosell
[submodule "rreversegeocoder"]
	path = rreversegeocoder
	url = https://github.com/jrosell/rreversegeocoder
